# ── Database (NestJS/TypeORM) ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=toptutor
DB_PASSWORD=change_me_strong_password
DB_NAME=toptutor_manager

# ── Database (PostgreSQL 컨테이너 — DB_* 와 값 동일하게 유지) ──────────────────
POSTGRES_USER=toptutor
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=toptutor_manager

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
DB_SYNC=true   # 첫 배포 시 테이블 자동 생성. 이후 false로 변경 권장

# ── CORS ─────────────────────────────────────────────────────────────────────
# 서비스할 도메인 또는 http://서버IP
FRONTEND_URL=http://localhost

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ── SMTP (이메일 인증) ─────────────────────────────────────────────────────────
SMTP_HOST=smtp.naver.com
SMTP_PORT=465
SMTP_USER=your_email@naver.com
SMTP_PASS=your_smtp_password
SMTP_FROM=마더텅 매니저 <your_email@naver.com>
