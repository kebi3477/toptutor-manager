# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_NAME=toptutor_manager

# App
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=your-strong-secret-key-here
JWT_EXPIRES_IN=7d

# SMTP (이메일 인증 발송 — 미입력 시 콘솔에 코드 출력)
# 네이버: 설정 > 환경설정 > POP3/IMAP 설정 > SMTP 사용 ON 후 비밀번호 입력
SMTP_HOST=smtp.naver.com
SMTP_PORT=465
SMTP_USER=your-id@naver.com
SMTP_PASS=your-naver-password
SMTP_FROM=마더텅 매니저 <your-id@naver.com>
