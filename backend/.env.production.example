# Database (PostgreSQL 컨테이너)
DB_HOST=db
DB_PORT=5432
DB_USERNAME=toptutor
DB_PASSWORD=변경하세요_강력한비밀번호
DB_NAME=toptutor_manager
DB_SYNC=true

# PostgreSQL 컨테이너 초기화 (DB_* 값과 동일하게 유지)
POSTGRES_USER=toptutor
POSTGRES_PASSWORD=변경하세요_강력한비밀번호
POSTGRES_DB=toptutor_manager

# App
PORT=3001
NODE_ENV=production

# JWT (반드시 변경)
JWT_SECRET=변경하세요_랜덤64자이상문자열
JWT_EXPIRES_IN=7d

# CORS (프론트엔드 도메인)
FRONTEND_URL=https://manager.toptutor.co.kr

# SMTP (이메일 인증)
SMTP_HOST=smtp.naver.com
SMTP_PORT=465
SMTP_USER=이메일주소@naver.com
SMTP_PASS=앱비밀번호
SMTP_FROM=TopTutor 매니저 <이메일주소@naver.com>
