# ── Database (NestJS/TypeORM) ─────────────────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_USERNAME=toptutor
DB_PASSWORD=변경하세요_강력한비밀번호
DB_NAME=toptutor_manager

# ── Database (PostgreSQL 컨테이너 — DB_* 와 값 동일하게 유지) ──────────────────
POSTGRES_USER=toptutor
POSTGRES_PASSWORD=변경하세요_강력한비밀번호
POSTGRES_DB=toptutor_manager

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
DB_SYNC=false   # 첫 배포 시 true로 변경해 테이블 생성 후 다시 false로 복원

# ── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://manager.toptutor.co.kr

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=변경하세요_랜덤64자이상문자열
JWT_EXPIRES_IN=7d

# ── SMTP (이메일 인증) ─────────────────────────────────────────────────────────
SMTP_HOST=smtp.naver.com
SMTP_PORT=465
SMTP_USER=your_email@naver.com
SMTP_PASS=your_smtp_password
SMTP_FROM=TopTutor 매니저 <your_email@naver.com>
